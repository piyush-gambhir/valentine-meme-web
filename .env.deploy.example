# Copy to .env.deploy.production or .env.deploy.development and fill in.
# Both files are gitignored — never commit real values.

# Cloudflare account ID — find on the right sidebar at https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=

# API token with Pages:Edit (and User Details:Read) permissions.
# Generate at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Pages project name (must already exist — create via dashboard or `wrangler pages project create`)
CF_PROJECT_NAME=valentine-meme

# Optional overrides
# BUILD_DIR=dist
# CF_PRODUCTION_BRANCH=main
# CF_PREVIEW_BRANCH=preview
